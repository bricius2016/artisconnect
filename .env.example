# ============================================================
# ArtisConnect — Variables d'environnement
# Copie ce fichier en .env.local et remplis les valeurs
# NE JAMAIS committer .env.local dans Git
# ============================================================

# Supabase — récupère ces valeurs sur https://supabase.com
# Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://TON_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=TON_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=TON_SERVICE_ROLE_KEY

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=ArtisConnect
